# Build the api as a static, CGO-free binary so it runs on the empty `scratch` image.
FROM docker.io/golang:1.22-alpine AS builder
WORKDIR /app
COPY main.go .
RUN go mod init api && CGO_ENABLED=0 GOOS=linux go build -ldflags='-s -w' -o api .

FROM scratch
COPY --from=builder /app/api /api
COPY data.json /data.json
EXPOSE 80
ENTRYPOINT ["/api"]
